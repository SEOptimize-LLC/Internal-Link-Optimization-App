# Google Search Console — OAuth2
# Create an OAuth 2.0 Client ID (Web application type) in Google Cloud Console
# APIs & Services > Credentials > Create Credentials > OAuth client ID
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8501

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_your-key-here

# Model Configuration (optional overrides)
MODEL_REASONING=anthropic/claude-sonnet-4-5
MODEL_FAST=google/gemini-2.0-flash

# Analysis Defaults (optional overrides)
GSC_DEFAULT_DAYS=90
MAX_PAGES_PER_BATCH=50
MAX_QUERIES_PER_CLUSTER_BATCH=200
